###############################################################################
# server.env  -  Konfiguration fuer LernApp Server
###############################################################################
#
# Diese Datei VOR der Installation bearbeiten!
# Dann:  sudo bash INSTALL.sh
#
###############################################################################

# === PFLICHT: Cloudflare Tunnel Token ===
# So bekommst du den Token (2 Minuten):
#   1. https://one.dash.cloudflare.com einloggen
#   2. Zero Trust -> Networks -> Tunnels
#   3. "Create a tunnel" klicken
#   4. Name: "lernapp"
#   5. Betriebssystem: "Debian" waehlen
#   6. Den Token-String (nach '--token') kopieren
#   7. Hier einfuegen:
#
# WICHTIG: Im Dashboard auch die Ingress-Regeln setzen:
#   Public Hostname: renlern.org     -> http://localhost:5000
#   Public Hostname: www.renlern.org -> http://localhost:5000
#
CLOUDFLARE_TUNNEL_TOKEN=""

# === EMPFOHLEN: SSH Public Key ===
# Wenn gesetzt: Passwort-Login wird automatisch deaktiviert (viel sicherer!)
# Deinen Public Key findest du auf deinem PC mit:
#   Windows: type %USERPROFILE%\.ssh\id_ed25519.pub
#   Linux:   cat ~/.ssh/id_ed25519.pub
#
# Falls du noch keinen hast:
#   ssh-keygen -t ed25519 -C "admin@lernapp"
#
ADMIN_SSH_PUBKEY=""

# === NETZWERK ===
# Dein lokales Netzwerk (fuer SSH-Zugriff und fail2ban Whitelist)
# Typisch: 192.168.1.0/24 oder 192.168.178.0/24 (FritzBox)
LAN_SUBNET="192.168.1.0/24"

# Optional: Nur EINE bestimmte IP darf SSH nutzen
# (Leer lassen = ganzes LAN darf SSH)
MANAGEMENT_IP=""

# === APP-EINSTELLUNGEN ===
APP_USER="lernapp"
APP_DIR="/opt/lernapp"
DOMAIN="renlern.org"
SSH_PORT=8022
FLASK_PORT=5000
